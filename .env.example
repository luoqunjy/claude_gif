# ============================================================
# LLM 配置 — 可同时填入多个供应商,启动后在左下角切换
# 采用 OpenAI 兼容协议
# ============================================================

# 默认使用哪个(deepseek / kimi / openai / qwen)
# 不填则自动用第一个已配置的
LLM_ACTIVE=deepseek

# ------------- DeepSeek -------------
# 申请: https://platform.deepseek.com  (国内,中文强,便宜,不支持识图)
LLM_DEEPSEEK_API_KEY=
LLM_DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
LLM_DEEPSEEK_MODEL=deepseek-chat

# ------------- Kimi / 月之暗面 -------------
# 申请: https://platform.moonshot.cn  (国内,长上下文,不支持识图)
LLM_KIMI_API_KEY=
LLM_KIMI_BASE_URL=https://api.moonshot.cn/v1
LLM_KIMI_MODEL=moonshot-v1-8k

# ------------- OpenAI -------------
# 申请: https://platform.openai.com   (需海外网络,gpt-4o-mini 支持识图)
LLM_OPENAI_API_KEY=
LLM_OPENAI_BASE_URL=https://api.openai.com/v1
LLM_OPENAI_MODEL=gpt-4o-mini

# ------------- 通义千问(可选,支持识图) -------------
# 申请: https://bailian.console.aliyun.com
# LLM_QWEN_API_KEY=
# LLM_QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# LLM_QWEN_MODEL=qwen-vl-plus

# ============================================================
# 服务配置
# ============================================================
PORT=3000
